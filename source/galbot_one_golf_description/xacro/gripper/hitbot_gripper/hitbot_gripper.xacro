<robot xmlns:xacro="http://ros.org/wiki/xacro" name="hitbot_gripper">

  <xacro:macro name="hitbot_gripper"
    params="parent *origin name:=hitbot_gripper collision_type:=convex_decomposition">
    <xacro:property name="M_PI" value="3.1415926535897931" />

    <joint name="${name}_joint" type="fixed">
      <xacro:insert_block name="origin" />
      <parent link="${parent}" />
      <child link="${name}_base_link" />
    </joint>

    <link name="${name}_base_link">
      <inertial>
        <origin xyz="0.0828 0.03604 -7.000000000000001e-05" rpy="0 0 0" />
        <mass value="0.878" />
        <inertia ixx="0.0011546199999999999" ixy="0.0026213200000000003"
          ixz="-5.0899999999999995e-06" iyy="0.00603809" iyz="-2.31e-06" izz="0.0071770900000000006" />
      </inertial>
      <visual>
        <origin xyz="0 0 0" rpy="0 0 0" />
        <geometry>
          <mesh
            filename="package://galbot_one_golf_description/meshes/visual/gripper/hitbot_gripper/base_link/obj/base_link.obj" />
        </geometry>
      </visual>
      <xacro:if value="${collision_type == 'sphere'}">
        <collision>
          <origin xyz="0 0 0" rpy="0 0 0" />
          <geometry>
            <sphere radius="0.05" />
          </geometry>
        </collision>
      </xacro:if>
      <xacro:if value="${collision_type == 'mesh'}">
        <collision>
          <origin xyz="0 0 0" rpy="0 0 0" />
          <geometry>
            <mesh
              filename="package://galbot_one_golf_description/meshes/collision/gripper/hitbot_gripper/base_link/original/base_link.stl" />
          </geometry>
        </collision>
      </xacro:if>
      <xacro:if value="${collision_type == 'convex_hull'}">
        <collision>
          <origin xyz="0 0 0" rpy="0 0 0" />
          <geometry>
            <mesh
              filename="package://galbot_one_golf_description/meshes/collision/gripper/hitbot_gripper/base_link/convex_hull/base_link_convex_hull.stl" />
          </geometry>
        </collision>
      </xacro:if>
      <xacro:if value="${collision_type == 'convex_decomposition'}">
        <collision>
          <origin xyz="0 0 0" rpy="0 0 0" />
          <geometry>
            <mesh
              filename="package://galbot_one_golf_description/meshes/collision/gripper/hitbot_gripper/base_link/convex_decomposition/base_link_convex_decomposition_0.stl" />
          </geometry>
        </collision>
        <collision>
          <origin xyz="0 0 0" rpy="0 0 0" />
