          <origin xyz="0 0 0" rpy="0 0 0" />
          <geometry>
            <mesh
              filename="package://galbot_one_golf_description/meshes/collision/gripper/hitbot_gripper/gripper_link6/convex_decomposition/gripper_link6_convex_decomposition_0.stl" />
          </geometry>
        </collision>
        <collision>
          <origin xyz="0 0 0" rpy="0 0 0" />
          <geometry>
            <mesh
              filename="package://galbot_one_golf_description/meshes/collision/gripper/hitbot_gripper/gripper_link6/convex_decomposition/gripper_link6_convex_decomposition_1.stl" />
          </geometry>
        </collision>
      </xacro:if>
    </link>

    <joint name="${name}_joint6" type="revolute">
      <origin xyz="0.065 0 0" rpy="0 0 ${M_PI/4}" />
      <parent link="${name}_link5" />
      <child link="${name}_link6" />
      <axis xyz="0 0 -1" />
      <limit lower="-6.28" upper="6.28" velocity="2.0" effort="50" /> <!-- Fake effort and velocity
      for
      gripper -->
    </joint>

    <!-- Tool Center Point -->
    <link name="${name}_tcp_link" />
    <joint name="${name}_tcp_joint" type="fixed">
      <origin xyz="0.222892 0 0 " rpy="0 0 0" />
      <parent link="${name}_base_link" />
      <child link="${name}_tcp_link" />
      <axis xyz="0 0 0" />
    </joint>

  </xacro:macro>
</robot>