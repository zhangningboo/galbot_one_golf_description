          <mesh filename="package://galbot_one_golf_description/meshes/collision/gripper/galbot_gripper1/convex_decomposition/base_link_convex_decomposition/base_link_convex_decomposition_54.stl" />
        </geometry>
      </collision>
      <collision>
        <origin xyz="0 0 0" rpy="0 0 0" />
        <geometry>
          <mesh filename="package://galbot_one_golf_description/meshes/collision/gripper/galbot_gripper1/convex_decomposition/base_link_convex_decomposition/base_link_convex_decomposition_55.stl" />
        </geometry>
      </collision>
      <collision>
        <origin xyz="0 0 0" rpy="0 0 0" />
        <geometry>
          <mesh filename="package://galbot_one_golf_description/meshes/collision/gripper/galbot_gripper1/convex_decomposition/base_link_convex_decomposition/base_link_convex_decomposition_56.stl" />
        </geometry>
      </collision>
      <collision>
        <origin xyz="0 0 0" rpy="0 0 0" />
        <geometry>
          <mesh filename="package://galbot_one_golf_description/meshes/collision/gripper/galbot_gripper1/convex_decomposition/base_link_convex_decomposition/base_link_convex_decomposition_57.stl" />
        </geometry>
      </collision>
      <collision>
        <origin xyz="0 0 0" rpy="0 0 0" />
        <geometry>
          <mesh filename="package://galbot_one_golf_description/meshes/collision/gripper/galbot_gripper1/convex_decomposition/base_link_convex_decomposition/base_link_convex_decomposition_58.stl" />
        </geometry>
      </collision>
      <collision>
        <origin xyz="0 0 0" rpy="0 0 0" />
        <geometry>
          <mesh filename="package://galbot_one_golf_description/meshes/collision/gripper/galbot_gripper1/convex_decomposition/base_link_convex_decomposition/base_link_convex_decomposition_59.stl" />
        </geometry>
      </collision>
      <collision>
        <origin xyz="0 0 0" rpy="0 0 0" />
        <geometry>
          <mesh filename="package://galbot_one_golf_description/meshes/collision/gripper/galbot_gripper1/convex_decomposition/base_link_convex_decomposition/base_link_convex_decomposition_60.stl" />
        </geometry>
      </collision>
      <collision>
        <origin xyz="0 0 0" rpy="0 0 0" />
        <geometry>
          <mesh filename="package://galbot_one_golf_description/meshes/collision/gripper/galbot_gripper1/convex_decomposition/base_link_convex_decomposition/base_link_convex_decomposition_61.stl" />
        </geometry>
      </collision>
      <collision>
        <origin xyz="0 0 0" rpy="0 0 0" />
        <geometry>
          <mesh filename="package://galbot_one_golf_description/meshes/collision/gripper/galbot_gripper1/convex_decomposition/base_link_convex_decomposition/base_link_convex_decomposition_62.stl" />
        </geometry>
      </collision>
      <collision>
        <origin xyz="0 0 0" rpy="0 0 0" />
        <geometry>
          <mesh filename="package://galbot_one_golf_description/meshes/collision/gripper/galbot_gripper1/convex_decomposition/base_link_convex_decomposition/base_link_convex_decomposition_63.stl" />
        </geometry>
      </collision>
      <collision>
        <origin xyz="0 0 0" rpy="0 0 0" />
        <geometry>
          <mesh filename="package://galbot_one_golf_description/meshes/collision/gripper/galbot_gripper1/convex_decomposition/base_link_convex_decomposition/base_link_convex_decomposition_64.stl" />
        </geometry>
      </collision>
      <collision>
        <origin xyz="0 0 0" rpy="0 0 0" />
        <geometry>
          <mesh filename="package://galbot_one_golf_description/meshes/collision/gripper/galbot_gripper1/convex_decomposition/base_link_convex_decomposition/base_link_convex_decomposition_65.stl" />
        </geometry>
      </collision>
      <collision>
        <origin xyz="0 0 0" rpy="0 0 0" />
        <geometry>
          <mesh filename="package://galbot_one_golf_description/meshes/collision/gripper/galbot_gripper1/convex_decomposition/base_link_convex_decomposition/base_link_convex_decomposition_66.stl" />
        </geometry>
      </collision>
      <collision>
        <origin xyz="0 0 0" rpy="0 0 0" />
        <geometry>
          <mesh filename="package://galbot_one_golf_description/meshes/collision/gripper/galbot_gripper1/convex_decomposition/base_link_convex_decomposition/base_link_convex_decomposition_67.stl" />
        </geometry>
      </collision>
      <collision>
        <origin xyz="0 0 0" rpy="0 0 0" />
        <geometry>
          <mesh filename="package://galbot_one_golf_description/meshes/collision/gripper/galbot_gripper1/convex_decomposition/base_link_convex_decomposition/base_link_convex_decomposition_68.stl" />
        </geometry>
      </collision>
      <collision>
        <origin xyz="0 0 0" rpy="0 0 0" />
        <geometry>
          <mesh filename="package://galbot_one_golf_description/meshes/collision/gripper/galbot_gripper1/convex_decomposition/base_link_convex_decomposition/base_link_convex_decomposition_69.stl" />
        </geometry>
      </collision>
      </xacro:if>
    </link>
    
    <!-- 手指宏 -->
    <xacro:macro name="finger" params="link_prefix mesh_prefix mirror collision_type"> 
      <!-- 指节 -->
      <link name="${link_prefix}_knuckle_link">
        <inertial>
          <origin xyz="0.024101 0 0" rpy="0 0 0"/>
          <mass value="0.0070682"/>
          <inertia 
            ixx="9.2131e-08" 
            ixy="0" 
            ixz="0"
            iyy="1.559e-06" 
            iyz="0" 
            izz="1.4931e-06"/>
        </inertial>
        <visual>
          <geometry>
            <mesh filename="package://galbot_one_golf_description/meshes/visual/gripper/galbot_gripper1/${mesh_prefix}_link_1.obj"/>
          </geometry>

        </visual>


        <!-- 原始碰撞模型 -->
        <xacro:if value="${collision_type == 'mesh'}">
          <collision>
            <origin xyz="0 0 0" rpy="0 0 0" />
            <geometry>
              <mesh
                filename="package://galbot_one_golf_description/meshes/collision/gripper/galbot_gripper1/original/${mesh_prefix}_link_1.stl" />
            </geometry>
          </collision>
        </xacro:if>
        <!-- 球碰撞模型 -->
        <xacro:if value="${collision_type == 'sphere'}">
          <collision>
            <origin xyz="0 0 0" rpy="0 0 0" />
            <geometry>
              <sphere radius="0.005" />
            </geometry>
          </collision>
        </xacro:if>
        <!-- 凸包碰撞模型 -->
        <xacro:if value="${collision_type == 'convex_hull'}">
          <collision>
            <origin xyz="0 0 0" rpy="0 0 0" />
            <geometry>
              <mesh filename="package://galbot_one_golf_description/meshes/collision/gripper/galbot_gripper1/convex_hull/${mesh_prefix}_link_1_convex_hull.stl" />
            </geometry>
          </collision>
        </xacro:if>
        <!-- 凸分解碰撞模型 -->
        <xacro:if value="${collision_type == 'convex_decomposition'}">
          <collision>
            <origin xyz="0 0 0" rpy="0 0 0" />
            <geometry>
              <mesh filename="package://galbot_one_golf_description/meshes/collision/gripper/galbot_gripper1/convex_decomposition/${mesh_prefix}_link_1_convex_decomposition/${mesh_prefix}_link_1_convex_decomposition_0.stl" />
            </geometry>
          </collision>
          <collision>
            <origin xyz="0 0 0" rpy="0 0 0" />
            <geometry>
              <mesh filename="package://galbot_one_golf_description/meshes/collision/gripper/galbot_gripper1/convex_decomposition/${mesh_prefix}_link_1_convex_decomposition/${mesh_prefix}_link_1_convex_decomposition_1.stl" />
            </geometry>
          </collision>
        </xacro:if>
      </link>


      <!-- 内指节 -->
      <link name="${link_prefix}_inner_knuckle_link">
        <inertial>
          <origin xyz="0.023769 0 0" rpy="0 0 0"/>
          <mass value="0.007802"/>
          <inertia 
            ixx="1.044e-07" 
            ixy="0" 
            ixz="0"
            iyy="1.6385e-06" 
            iyz="0" 
            izz="1.566e-06"/>
        </inertial>
        <visual>
          <geometry>
            <mesh filename="package://galbot_one_golf_description/meshes/visual/gripper/galbot_gripper1/${mesh_prefix}_link_2.obj"/>
          </geometry>
        </visual>


        <!-- 原始碰撞模型 -->
        <xacro:if value="${collision_type == 'mesh'}">
          <collision>
            <origin xyz="0 0 0" rpy="0 0 0" />
            <geometry>
              <mesh filename="package://galbot_one_golf_description/meshes/collision/gripper/galbot_gripper1/original/${mesh_prefix}_link_2.stl"/>
            </geometry>
          </collision>
        </xacro:if>

        <xacro:if value="${collision_type == 'sphere'}">
          <collision>
            <origin xyz="0 0 0" rpy="0 0 0" />
            <geometry>
              <sphere radius="0.005" />
            </geometry>
          </collision>
        </xacro:if>
        <!-- 凸包碰撞模型 -->
        <xacro:if value="${collision_type == 'convex_hull'}">
          <collision>
            <origin xyz="0 0 0" rpy="0 0 0" />
            <geometry>
              <mesh filename="package://galbot_one_golf_description/meshes/collision/gripper/galbot_gripper1/convex_hull/${mesh_prefix}_link_2_convex_hull.stl" />
            </geometry>
          </collision>
        </xacro:if>
        <!-- 凸分解碰撞模型 -->
        <xacro:if value="${collision_type == 'convex_decomposition'}">
          <collision>
            <origin xyz="0 0 0" rpy="0 0 0" />
            <geometry>
              <mesh filename="package://galbot_one_golf_description/meshes/collision/gripper/galbot_gripper1/convex_decomposition/${mesh_prefix}_link_2_convex_decomposition/${mesh_prefix}_link_2_convex_decomposition_0.stl" />
            </geometry>
          </collision>
          <collision>
            <origin xyz="0 0 0" rpy="0 0 0" />
            <geometry>
              <mesh filename="package://galbot_one_golf_description/meshes/collision/gripper/galbot_gripper1/convex_decomposition/${mesh_prefix}_link_2_convex_decomposition/${mesh_prefix}_link_2_convex_decomposition_1.stl" />
            </geometry>
          </collision>
        </xacro:if>
      </link>

      <joint name="${link_prefix}_inner_knuckle_joint" type="revolute">
        <parent link="${name}_base_link"/>
        <child link="${link_prefix}_inner_knuckle_link"/>
        <origin xyz="0.079 0 ${-0.026*mirror}" rpy="${M_PI/2} ${1.2465*mirror} 0"/>
        <axis xyz="0 0 1"/>
        <limit lower="-3.13" upper="3.13" velocity="2.0" effort="1000"/>
        <mimic joint="${name}_r_knuckle_joint" multiplier="${mimic_scale*mirror}"/>
      </joint>
      <xacro:if value="${tool_type == 'ori'}">
          <!-- 指尖 -->
          <link name="${link_prefix}_finger_link">
            <inertial>
              <origin xyz="0.016809 ${0.0019094*mirror} 0" rpy="0 0 0"/>
              <mass value="0.015957"/>
              <inertia 
                ixx="5.5426e-07" 
                ixy="0" 
                ixz="0"
                iyy="1.8538e-06" 
                iyz="0" 
                izz="1.5262e-06"/>
            </inertial>
            <visual>
              <geometry>
                <mesh filename="package://galbot_one_golf_description/meshes/visual/gripper/galbot_gripper1/${mesh_prefix}_link_3.obj"/>
              </geometry>
            </visual>

      
            <!-- 原始碰撞模型 -->
            <xacro:if value="${collision_type == 'mesh'}">
              <collision>
                <origin xyz="0 0 0" rpy="0 0 0" />
                <geometry>
                  <mesh filename="package://galbot_one_golf_description/meshes/collision/gripper/galbot_gripper1/original/${mesh_prefix}_link_3.stl"/>
                </geometry>
              </collision>
            </xacro:if>
            <!-- 球碰撞模型 -->
            <xacro:if value="${collision_type == 'sphere'}">
              <collision>
                <origin xyz="0 0 0" rpy="0 0 0" />
                <geometry>
                  <sphere radius="0.005" />
                </geometry>
              </collision>
            </xacro:if>
            <!-- 凸包碰撞模型 -->
            <xacro:if value="${collision_type == 'convex_hull'}">
              <collision>
                <origin xyz="0 0 0" rpy="0 0 0" />
                <geometry>
                  <mesh filename="package://galbot_one_golf_description/meshes/collision/gripper/galbot_gripper1/convex_hull/${mesh_prefix}_link_3_convex_hull.stl" />
                </geometry>
              </collision>
            </xacro:if>
            <!-- 凸分解碰撞模型 -->
            <xacro:if value="${collision_type == 'convex_decomposition'}">
              <collision>
                <origin xyz="0 0 0" rpy="0 0 0" />
                <geometry>
                  <mesh filename="package://galbot_one_golf_description/meshes/collision/gripper/galbot_gripper1/convex_decomposition/${mesh_prefix}_link_3_convex_decomposition/${mesh_prefix}_link_3_convex_decomposition_0.stl" />
                </geometry>
              </collision>
              <collision>
                <origin xyz="0 0 0" rpy="0 0 0" />
                <geometry>
                  <mesh filename="package://galbot_one_golf_description/meshes/collision/gripper/galbot_gripper1/convex_decomposition/${mesh_prefix}_link_3_convex_decomposition/${mesh_prefix}_link_3_convex_decomposition_1.stl" />
                </geometry>
              </collision>
              <collision>
                <origin xyz="0 0 0" rpy="0 0 0" />
                <geometry>
                  <mesh filename="package://galbot_one_golf_description/meshes/collision/gripper/galbot_gripper1/convex_decomposition/${mesh_prefix}_link_3_convex_decomposition/${mesh_prefix}_link_3_convex_decomposition_2.stl" />
                </geometry>
              </collision>
              <collision>
                <origin xyz="0 0 0" rpy="0 0 0" />
                <geometry>
                  <mesh filename="package://galbot_one_golf_description/meshes/collision/gripper/galbot_gripper1/convex_decomposition/${mesh_prefix}_link_3_convex_decomposition/${mesh_prefix}_link_3_convex_decomposition_3.stl" />
                </geometry>
              </collision>
            </xacro:if>
          </link>
      </xacro:if>


      <xacro:if value="${tool_type == 'zhitao'}">
          <!-- 指尖 -->
          <link name="${link_prefix}_finger_link">
            <inertial>
              <origin xyz="0.016809 ${0.0019094*mirror} 0" rpy="0 0 0"/>
              <mass value="0.015957"/>
              <inertia 
                ixx="5.5426e-07" 
                ixy="0" 
                ixz="0"
                iyy="1.8538e-06" 
                iyz="0" 
                izz="1.5262e-06"/>
            </inertial>
            <visual>
              <geometry>
                <mesh filename="package://galbot_one_golf_description/meshes/visual/gripper/galbot_gripper1/${mesh_prefix}_link_3_zhitao.obj"/>
              </geometry>
            </visual>

      
            <!-- 原始碰撞模型 -->
            <xacro:if value="${collision_type == 'mesh'}">
              <collision>
                <origin xyz="0 0 0" rpy="0 0 0" />
                <geometry>
                  <mesh filename="package://galbot_one_golf_description/meshes/collision/gripper/galbot_gripper1/original/${mesh_prefix}_link_3_zhitao.stl"/>
                </geometry>
              </collision>
            </xacro:if>
            <!-- 球碰撞模型 -->
            <xacro:if value="${collision_type == 'sphere'}">
              <collision>
                <origin xyz="0 0 0" rpy="0 0 0" />
                <geometry>
                  <sphere radius="0.015" />
                </geometry>
              </collision>
              <collision>
                <origin xyz="0.02 0 0" rpy="0 0 0" />
                <geometry>
                  <sphere radius="0.015" />
                </geometry>
              </collision>
              <collision>
                <origin xyz="0.04 0 0" rpy="0 0 0" />
                <geometry>
                  <sphere radius="0.015" />
                </geometry>
              </collision>
              <collision>
                <origin xyz="0.06 0 0" rpy="0 0 0" />
                <geometry>
                  <sphere radius="0.01" />
                </geometry>
              </collision>
            </xacro:if>
            <!-- 凸包碰撞模型 -->
            <xacro:if value="${collision_type == 'convex_hull'}">
              <collision>
                <origin xyz="0 0 0" rpy="0 0 0" />
                <geometry>
                  <mesh filename="package://galbot_one_golf_description/meshes/collision/gripper/galbot_gripper1/convex_hull/${mesh_prefix}_link_3_zhitao_convex_hull.stl" />
                </geometry>
              </collision>
            </xacro:if>
            <!-- 凸分解碰撞模型 -->
            <xacro:if value="${collision_type == 'convex_decomposition'}">
              <xacro:if value="${mesh_prefix == 'l'}">
                <!-- Left finger (6 parts) -->
                <collision>
                  <origin xyz="0 0 0" rpy="0 0 0" />
                  <geometry>
                    <mesh filename="package://galbot_one_golf_description/meshes/collision/gripper/galbot_gripper1/convex_decomposition/${mesh_prefix}_link_3_zhitao_convex_decomposition/${mesh_prefix}_link_3_zhitao_convex_decomposition_0.stl" />
                  </geometry>
                </collision>
                <collision>
                  <origin xyz="0 0 0" rpy="0 0 0" />
                  <geometry>
                    <mesh filename="package://galbot_one_golf_description/meshes/collision/gripper/galbot_gripper1/convex_decomposition/${mesh_prefix}_link_3_zhitao_convex_decomposition/${mesh_prefix}_link_3_zhitao_convex_decomposition_1.stl" />
                  </geometry>
                </collision>
                <collision>
                  <origin xyz="0 0 0" rpy="0 0 0" />
                  <geometry>
                    <mesh filename="package://galbot_one_golf_description/meshes/collision/gripper/galbot_gripper1/convex_decomposition/${mesh_prefix}_link_3_zhitao_convex_decomposition/${mesh_prefix}_link_3_zhitao_convex_decomposition_2.stl" />
                  </geometry>
                </collision>
                <collision>
                  <origin xyz="0 0 0" rpy="0 0 0" />
                  <geometry>
                    <mesh filename="package://galbot_one_golf_description/meshes/collision/gripper/galbot_gripper1/convex_decomposition/${mesh_prefix}_link_3_zhitao_convex_decomposition/${mesh_prefix}_link_3_zhitao_convex_decomposition_3.stl" />
                  </geometry>
                </collision>
                <collision>
                  <origin xyz="0 0 0" rpy="0 0 0" />
                  <geometry>
                    <mesh filename="package://galbot_one_golf_description/meshes/collision/gripper/galbot_gripper1/convex_decomposition/${mesh_prefix}_link_3_zhitao_convex_decomposition/${mesh_prefix}_link_3_zhitao_convex_decomposition_4.stl" />
                  </geometry>
                </collision>
                <collision>
                  <origin xyz="0 0 0" rpy="0 0 0" />
                  <geometry>
                    <mesh filename="package://galbot_one_golf_description/meshes/collision/gripper/galbot_gripper1/convex_decomposition/${mesh_prefix}_link_3_zhitao_convex_decomposition/${mesh_prefix}_link_3_zhitao_convex_decomposition_5.stl" />
                  </geometry>
                </collision>
              </xacro:if>
              
              <xacro:if value="${mesh_prefix == 'r'}">
                <!-- Right finger (4 parts) -->
                <collision>
                  <origin xyz="0 0 0" rpy="0 0 0" />
                  <geometry>
                    <mesh filename="package://galbot_one_golf_description/meshes/collision/gripper/galbot_gripper1/convex_decomposition/${mesh_prefix}_link_3_zhitao_convex_decomposition/${mesh_prefix}_link_3_zhitao_convex_decomposition_0.stl" />
                  </geometry>
                </collision>
                <collision>
                  <origin xyz="0 0 0" rpy="0 0 0" />
                  <geometry>
                    <mesh filename="package://galbot_one_golf_description/meshes/collision/gripper/galbot_gripper1/convex_decomposition/${mesh_prefix}_link_3_zhitao_convex_decomposition/${mesh_prefix}_link_3_zhitao_convex_decomposition_1.stl" />
                  </geometry>
                </collision>
                <collision>
                  <origin xyz="0 0 0" rpy="0 0 0" />
                  <geometry>
                    <mesh filename="package://galbot_one_golf_description/meshes/collision/gripper/galbot_gripper1/convex_decomposition/${mesh_prefix}_link_3_zhitao_convex_decomposition/${mesh_prefix}_link_3_zhitao_convex_decomposition_2.stl" />
                  </geometry>
                </collision>
                <collision>
                  <origin xyz="0 0 0" rpy="0 0 0" />
                  <geometry>
                    <mesh filename="package://galbot_one_golf_description/meshes/collision/gripper/galbot_gripper1/convex_decomposition/${mesh_prefix}_link_3_zhitao_convex_decomposition/${mesh_prefix}_link_3_zhitao_convex_decomposition_3.stl" />
                  </geometry>
                </collision>
              </xacro:if>
            </xacro:if>
          </link>
      </xacro:if>

      <joint name="${link_prefix}_finger_joint" type="revolute">
        <parent link="${link_prefix}_inner_knuckle_link"/>
        <child link="${link_prefix}_finger_link"/>
        <origin xyz="0.045 0 0" rpy="0 0 ${1.2465*mirror}"/>
        <axis xyz="0 0 1"/>
        <limit lower="-3.13" upper="3.13" velocity="2.0" effort="1000"/>
        <mimic joint="${name}_r_knuckle_joint" multiplier="${mimic_scale*-mirror}"/>
      </joint>
    </xacro:macro>

    <!-- 生成手指，传递碰撞类型参数 -->
    <xacro:finger 
      link_prefix="${name}_l" 
      mesh_prefix="l" 
      mirror="1" 
      collision_type="${collision_type}"
    /> 
    <xacro:finger 
      link_prefix="${name}_r" 
      mesh_prefix="r" 
      mirror="-1" 
      collision_type="${collision_type}"
    />

    <!-- 右侧指节关节（主动关节） -->
    <joint name="${name}_r_knuckle_joint" type="revolute">
      <parent link="${name}_base_link" />
      <child link="${name}_r_knuckle_link" />
      <origin xyz="0.0745 0 ${-0.0385*-1}" rpy="${M_PI/2} ${1.2465*-1} 0"/>
      <axis xyz="0 0 -1" />
      <limit lower="0.0" upper="1.703" velocity="0.5" effort="50" />
    </joint>

    <!-- 左侧指节关节 -->
    <joint name="${name}_l_knuckle_joint" type="revolute">
      <parent link="${name}_base_link" />
      <child link="${name}_l_knuckle_link" />
      <origin xyz="0.0745 0 ${-0.0385*1}" rpy="${M_PI/2} ${1.2465*1} 0"/>
      <axis xyz="0 0 1" />
      <limit lower="-3.13" upper="3.13" velocity="0.5" effort="50" />
      <mimic joint="${name}_r_knuckle_joint" multiplier="1" />
    </joint>



    <!-- TCP -->
    <link name="${name}_tcp_link"></link>

    <joint name="${name}_tcp_joint" type="fixed">
      <parent link="${name}_base_link"/>
      <child link="${name}_tcp_link"/>
      <origin xyz="0.13996 0 0" rpy="-${M_PI/2} 0 0"/>
    </joint>
  </xacro:macro>

</robot>