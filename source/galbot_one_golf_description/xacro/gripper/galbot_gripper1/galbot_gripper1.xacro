<robot xmlns:xacro="http://www.ros.org/wiki/xacro" name="galbot_gripper1">

  <xacro:macro name="galbot_gripper1" params="parent *origin name:=galbot_gripper1 collision_type:=convex_decomposition  tool_type:=zhitao"  >
    <xacro:property name="M_PI" value="3.1415926535897931" />
    <xacro:property name="mimic_scale" value="1"/>
    <xacro:property name="control_prefix" value="${name}_r"/> 
    <!-- 使用右侧外指作为驱动关节 -->
    <!-- 固定关节连接父级 -->
    <joint name="${name}_joint" type="fixed">
      <xacro:insert_block name="origin" />
      <parent link="${parent}" />
      <child link="${name}_flange_link" />
    </joint>
    
    <link name="${name}_flange_link">
      <inertial>
        <origin xyz="0.0030662 -1.4019E-18 3.383E-18" rpy="0 0 0" />
        <mass value="0.031005" />
        <inertia 
          ixx="2.2585E-05" ixy="-2.0366E-21" ixz="-3.7461E-22"
          iyy="1.141E-05"  iyz="-7.8518E-23" izz="1.141E-05" />
      </inertial>
      <visual>
        <geometry>
          <mesh filename="package://galbot_one_golf_description/meshes/visual/gripper/galbot_gripper1/flange_link.obj" /> 
        </geometry>
      </visual>

      <xacro:if value="${collision_type == 'mesh'}">
        <collision>
          <origin xyz="0 0 0" rpy="0 0 0" />
          <geometry>
            <mesh filename="package://galbot_one_golf_description/meshes/visual/gripper/galbot_gripper1/flange_link.stl" /> 
          </geometry>
        </collision>
      </xacro:if>
      <xacro:if value="${collision_type == 'sphere'}">
        <collision>
          <origin xyz="0 0 0" rpy="0 0 0" />
          <geometry>
            <sphere radius="0.01" />
          </geometry>
        </collision>
      </xacro:if>
       <!-- 凸包碰撞模型 -->
      <xacro:if value="${collision_type == 'convex_hull'}">
        <collision>
          <origin xyz="0 0 0" rpy="0 0 0" />
          <geometry>
            <mesh filename="package://galbot_one_golf_description/meshes/collision/gripper/galbot_gripper1/convex_hull/flange_link_convex_hull.stl" />
          </geometry>
        </collision>
      </xacro:if>
      <!-- 凸分解碰撞模型 -->
      <xacro:if value="${collision_type == 'convex_decomposition'}">
        <collision>
          <origin xyz="0 0 0" rpy="0 0 0" />
          <geometry>
            <mesh filename="package://galbot_one_golf_description/meshes/collision/gripper/galbot_gripper1/convex_hull/flange_link_convex_hull.stl" />
          </geometry>
        </collision>
      </xacro:if>

    </link>



    <!-- 新增：基链接固定关节（连接法兰和基链接） -->
    <joint name="${name}_base_joint" type="fixed">
      <origin xyz="0.0065 0 0" rpy="0 0 0" /> 
      <parent link="${name}_flange_link" />
      <child link="${name}_base_link" />
      <axis xyz="0 0 0" />
    </joint>

    <!-- 基础连杆 -->
    <link name="${name}_base_link">
      <inertial>
        <origin xyz="0.037051 -6.4001E-05 6.4706E-05" rpy="0 0 0" />
        <mass value="0.061747" />
        <inertia 
          ixx="2.5813E-05" 
          ixy="4.7224E-08" 
          ixz="-3.9403E-11"
          iyy="7.2859E-05" 
          iyz="-2.962E-10" 
          izz="5.7173E-05"/>
      </inertial>
      <visual>
        <geometry>
          <mesh filename="package://galbot_one_golf_description/meshes/visual/gripper/galbot_gripper1/base_link.obj"/>
        </geometry>
      </visual>


      <!-- 原始碰撞模型 -->
      <xacro:if value="${collision_type == 'mesh'}">
          <collision>
            <origin xyz="0 0 0" rpy="0 0 0" />
            <geometry>
              <mesh filename="package://galbot_one_golf_description/meshes/collision/gripper/galbot_gripper1/original/base_link.stl"/>
            </geometry>
          </collision>
        </xacro:if>
      <!-- 球碰撞模型 -->
        <xacro:if value="${collision_type == 'sphere'}">
          <collision>
            <origin xyz="0 0 0" rpy="0 0 0" />
            <geometry>
              <sphere radius="0.05" />
            </geometry>
          </collision>
        </xacro:if>
      <!-- 凸包碰撞模型 -->
      <xacro:if value="${collision_type == 'convex_hull'}">
        <collision>
          <origin xyz="0 0 0" rpy="0 0 0" />
          <geometry>
            <mesh filename="package://galbot_one_golf_description/meshes/collision/gripper/galbot_gripper1/convex_hull/base_link_convex_hull.stl" />
          </geometry>
        </collision>
      </xacro:if>
      <!-- 凸分解碰撞模型 -->
      <xacro:if value="${collision_type == 'convex_decomposition'}">
        <collision>
    <origin xyz="0 0 0" rpy="0 0 0" />
    <geometry>
      <mesh filename="package://galbot_one_golf_description/meshes/collision/gripper/galbot_gripper1/convex_decomposition/base_link_convex_decomposition/base_link_convex_decomposition_0.stl" />
    </geometry>
      </collision>
      <collision>
        <origin xyz="0 0 0" rpy="0 0 0" />
        <geometry>
          <mesh filename="package://galbot_one_golf_description/meshes/collision/gripper/galbot_gripper1/convex_decomposition/base_link_convex_decomposition/base_link_convex_decomposition_1.stl" />
