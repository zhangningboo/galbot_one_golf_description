        </collision>
        <collision>
          <origin xyz="0 0 0" rpy="0 0 0" />
          <geometry>
            <mesh
              filename="package://galbot_one_golf_description/meshes/collision/leg/leg_link5/convex_decomposition/leg_link5_convex_decomposition_1.stl" />
          </geometry>
        </collision>
        <collision>
          <origin xyz="0 0 0" rpy="0 0 0" />
          <geometry>
            <mesh
              filename="package://galbot_one_golf_description/meshes/collision/leg/leg_link5/convex_decomposition/leg_link5_convex_decomposition_2.stl" />
          </geometry>
        </collision>
        <collision>
          <origin xyz="0 0 0" rpy="0 0 0" />
          <geometry>
            <mesh
              filename="package://galbot_one_golf_description/meshes/collision/leg/leg_link5/convex_decomposition/leg_link5_convex_decomposition_3.stl" />
          </geometry>
        </collision>
        <collision>
          <origin xyz="0 0 0" rpy="0 0 0" />
          <geometry>
            <mesh
              filename="package://galbot_one_golf_description/meshes/collision/leg/leg_link5/convex_decomposition/leg_link5_convex_decomposition_4.stl" />
          </geometry>
        </collision>
        <collision>
          <origin xyz="0 0 0" rpy="0 0 0" />
          <geometry>
            <mesh
              filename="package://galbot_one_golf_description/meshes/collision/leg/leg_link5/convex_decomposition/leg_link5_convex_decomposition_5.stl" />
          </geometry>
        </collision>
        <collision>
          <origin xyz="0 0 0" rpy="0 0 0" />
          <geometry>
            <mesh
              filename="package://galbot_one_golf_description/meshes/collision/leg/leg_link5/convex_decomposition/leg_link5_convex_decomposition_6.stl" />
          </geometry>
        </collision>
        <collision>
          <origin xyz="0 0 0" rpy="0 0 0" />
          <geometry>
            <mesh
              filename="package://galbot_one_golf_description/meshes/collision/leg/leg_link5/convex_decomposition/leg_link5_convex_decomposition_7.stl" />
          </geometry>
        </collision>
        <collision>
          <origin xyz="0 0 0" rpy="0 0 0" />
          <geometry>
            <mesh
              filename="package://galbot_one_golf_description/meshes/collision/leg/leg_link5/convex_decomposition/leg_link5_convex_decomposition_8.stl" />
          </geometry>
        </collision>
        <collision>
          <origin xyz="0 0 0" rpy="0 0 0" />
          <geometry>
            <mesh
              filename="package://galbot_one_golf_description/meshes/collision/leg/leg_link5/convex_decomposition/leg_link5_convex_decomposition_9.stl" />
          </geometry>
        </collision>
        <collision>
          <origin xyz="0 0 0" rpy="0 0 0" />
          <geometry>
            <mesh
              filename="package://galbot_one_golf_description/meshes/collision/leg/leg_link5/convex_decomposition/leg_link5_convex_decomposition_10.stl" />
          </geometry>
        </collision>
        <collision>
          <origin xyz="0 0 0" rpy="0 0 0" />
          <geometry>
            <mesh
              filename="package://galbot_one_golf_description/meshes/collision/leg/leg_link5/convex_decomposition/leg_link5_convex_decomposition_11.stl" />
          </geometry>
        </collision>
      </xacro:if>
    </link>
    <joint name="${name}_joint5" type="revolute">
      <origin xyz="0 0 0" rpy="${M_PI/2} 0 0" />
      <parent link="${name}_link4" />
      <child link="${name}_link5" />
      <axis xyz="0 0 1" />
      <limit lower="-0.1645" upper="0.1645" effort="30" velocity="1" />  <!-- special soft limit for
      leg joint 5 (0.01 radians)-->
    </joint>

    <link name="${name}_end_effector_mount_link">
      <inertial>
        <origin xyz="0 0 0" rpy="0 0 0" />
        <mass value="0" />
        <inertia ixx="0" ixy="0" ixz="0" iyy="0" iyz="0" izz="0" />
