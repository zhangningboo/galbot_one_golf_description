        </collision>
      </xacro:if>
      <xacro:if value="${collision_type == 'convex_decomposition'}">
        <collision>
          <origin xyz="0 0 0" rpy="0 0 0" />
          <geometry>
            <mesh
              filename="package://galbot_one_golf_description/meshes/collision/leg/leg_link5/convex_decomposition/leg_link5_convex_decomposition_0.stl" />
