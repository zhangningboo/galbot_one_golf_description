<robot xmlns:xacro="http://ros.org/wiki/xacro" name="leg">

  <xacro:macro name="leg" params="parent *origin name:=leg collision_type:=convex_decomposition">
    <xacro:property name="M_PI" value="3.1415926535897931" />

    <joint name="${name}_joint" type="fixed">
      <xacro:insert_block name="origin" />
      <parent link="${parent}" />
      <child link="${name}_base_link" />
    </joint>

    <link name="${name}_base_link">
      <inertial>
        <origin xyz="7.000000000000001e-05 -0.05414 0.0" rpy="0 0 0" />
        <mass value="1.58" />
        <inertia ixx="0.00797474" ixy="8.35e-06" ixz="2e-08" iyy="0.00248067" iyz="6.9e-07"
          izz="0.00797203" />
      </inertial>
    </link>

    <link name="${name}_link1">
