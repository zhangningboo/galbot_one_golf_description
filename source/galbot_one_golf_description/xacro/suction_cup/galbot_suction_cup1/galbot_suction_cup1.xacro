<robot xmlns:xacro="http://www.ros.org/wiki/xacro" name="galbot_suction_cup1">

  <xacro:macro name="galbot_suction_cup1"
    params="parent *origin name:=galbot_suction_cup1 collision_type:=convex_decomposition">
    <xacro:property name="M_PI" value="3.1415926535897931" />

    <joint name="${name}_joint" type="fixed">
      <xacro:insert_block name="origin" />
      <parent link="${parent}" />
      <child link="${name}_base_link" />
    </joint>

    <link name="${name}_base_link">
      <inertial>
        <origin xyz="-4.0035E-05 -0.00015919 0.065665" rpy="0 0 0" />
        <mass value="0.36941" />
        <inertia ixx="0.00014564" ixy="3.5459E-07" ixz="-1.2386E-07" iyy="0.00016918"
          iyz="-4.0084E-07" izz="0.000219" />
      </inertial>
      <visual>
        <origin xyz="0 0 0" rpy="0 0 0" />
        <geometry>
          <mesh
            filename="package://galbot_one_golf_description/meshes/visual/suction_cup/galbot_suction_cup1/suction_cup_base_link/obj/suction_cup_base_link.obj" />
        </geometry>
      </visual>
      <xacro:if value="${collision_type == 'sphere'}">
        <collision>
          <origin xyz="0 0 0" rpy="0 0 0" />
          <geometry>
            <sphere radius="0.1" />
          </geometry>
        </collision>
      </xacro:if>
      <xacro:if value="${collision_type == 'mesh'}">
        <collision>
          <origin xyz="0 0 0" rpy="0 0 0" />
          <geometry>
            <mesh
              filename="package://galbot_one_golf_description/meshes/collision/suction_cup/galbot_suction_cup1/suction_cup_base_link/original/suction_cup_base_link.stl" />
          </geometry>
        </collision>
      </xacro:if>
      <xacro:if value="${collision_type == 'convex_hull'}">
        <collision>
          <origin xyz="0 0 0" rpy="0 0 0" />
          <geometry>
            <mesh
              filename="package://galbot_one_golf_description/meshes/collision/suction_cup/galbot_suction_cup1/suction_cup_base_link/convex_hull/suction_cup_base_link_convex_hull.stl" />
          </geometry>
        </collision>
      </xacro:if>
      <xacro:if value="${collision_type == 'convex_decomposition'}">
        <collision>
          <origin xyz="0 0 0" rpy="0 0 0" />
          <geometry>
            <mesh
              filename="package://galbot_one_golf_description/meshes/collision/suction_cup/galbot_suction_cup1/suction_cup_base_link/convex_decomposition/suction_cup_base_link_convex_decomposition_0.stl" />
          </geometry>
        </collision>
        <collision>
          <origin xyz="0 0 0" rpy="0 0 0" />
          <geometry>
            <mesh
              filename="package://galbot_one_golf_description/meshes/collision/suction_cup/galbot_suction_cup1/suction_cup_base_link/convex_decomposition/suction_cup_base_link_convex_decomposition_1.stl" />
          </geometry>
        </collision>
      </xacro:if>
    </link>

    <link name="${name}_link1">
      <inertial>
        <origin xyz="0.037966 -3.0191E-05 -4.2414E-08" rpy="0 0 0" />
        <mass value="0.063856" />
        <inertia ixx="7.1717E-06" ixy="1.7711E-08" ixz="-3.6994E-11" iyy="8.0256E-06"
          iyz="4.7383E-09" izz="7.78E-06" />
      </inertial>
      <visual>
        <origin xyz="0 0 0" rpy="0 0 0" />
        <geometry>
          <mesh
            filename="package://galbot_one_golf_description/meshes/visual/suction_cup/galbot_suction_cup1/suction_cup_link1/obj/suction_cup_link1.obj" />
        </geometry>
      </visual>
      <xacro:if value="${collision_type == 'sphere'}">
        <collision>
          <origin xyz="0 0 0" rpy="0 0 0" />
          <geometry>
            <sphere radius="0.1" />
          </geometry>
        </collision>
      </xacro:if>
      <xacro:if value="${collision_type == 'mesh'}">
        <collision>
          <origin xyz="0 0 0" rpy="0 0 0" />
          <geometry>
            <mesh
              filename="package://galbot_one_golf_description/meshes/collision/suction_cup/galbot_suction_cup1/suction_cup_link1/original/suction_cup_link1.stl" />
          </geometry>
        </collision>
      </xacro:if>
      <xacro:if value="${collision_type == 'convex_hull'}">
        <collision>
          <origin xyz="0 0 0" rpy="0 0 0" />
          <geometry>
            <mesh
              filename="package://galbot_one_golf_description/meshes/collision/suction_cup/galbot_suction_cup1/suction_cup_link1/convex_hull/suction_cup_link1_convex_hull.stl" />
          </geometry>
        </collision>
      </xacro:if>
      <xacro:if value="${collision_type == 'convex_decomposition'}">
        <collision>
          <origin xyz="0 0 0" rpy="0 0 0" />
          <geometry>
            <mesh
              filename="package://galbot_one_golf_description/meshes/collision/suction_cup/galbot_suction_cup1/suction_cup_link1/convex_decomposition/suction_cup_link1_convex_decomposition_0.stl" />
          </geometry>
        </collision>
      </xacro:if>
    </link>

    <joint name="${name}_joint1" type="revolute">
      <origin xyz="-0.1428 0 0" rpy="0 0 ${-M_PI/2}" />
      <parent link="${name}_base_link" />
      <child link="${name}_link1" />
      <axis xyz="0 0 1" />
      <limit lower="0" upper="1.570796327" effort="1" velocity="1.570796327" />
    </joint>

    <link name="${name}_tcp_link" />
    <joint name="${name}_tcp_joint" type="fixed">
      <origin xyz="0 -0.079807 0" rpy="${M_PI/2} 0 ${-M_PI/2}" />
      <parent link="${name}_link1" />
      <child link="${name}_tcp_link" />
      <axis xyz="0 0 0" />
    </joint>

  </xacro:macro>
</robot>