<robot xmlns:xacro="http://ros.org/wiki/xacro" name="head">
  <xacro:macro name="head" params="parent *origin name:=head collision_type:=convex_decomposition">
    <xacro:property name="M_PI" value="3.1415926535897931" />

    <joint name="${name}_joint" type="fixed">
      <xacro:insert_block name="origin" />
      <parent link="${parent}" />
      <child link="${name}_base_link" />
    </joint>

    <link name="${name}_base_link">
      <inertial>
        <origin xyz="0.023809999999999998 0.00032 0.01966" rpy="0 0 0" />
        <mass value="0.48" />
        <inertia ixx="0.0032910599999999997" ixy="8.32e-06" ixz="0.00044358" iyy="0.00375998"
          iyz="7.18e-06" izz="0.00221683" />
      </inertial>
    </link>

    <link name="${name}_link1">
      <inertial>
        <origin xyz="-2e-05 0.00709 -0.0559" rpy="0 0 0" />
        <mass value="1.5695"/>
        <inertia ixx="0.0069002956" ixy="0.00000152205" ixz="0.00000313295"
             iyy="0.00683300359" iyz="0.00001009318" izz="0.00116967635"/>
      </inertial>
      <visual>
        <origin xyz="0 0 0" rpy="0 0 0" />
        <geometry>
          <mesh
            filename="package://galbot_one_golf_description/meshes/visual/head/head_link1/obj/head_link1.obj" />
        </geometry>
      </visual>
      <xacro:if value="${collision_type == 'sphere'}">
        <collision>
          <origin xyz="0.03 0.0 0.05" rpy="0 0 0" />
          <geometry>
            <sphere radius="0.1" />
          </geometry>
        </collision>
      </xacro:if>
      <xacro:if value="${collision_type == 'mesh'}">
        <collision>
          <origin xyz="0 0 0" rpy="0 0 0" />
          <geometry>
            <mesh
              filename="package://galbot_one_golf_description/meshes/collision/head/head_link1/original/head_link1.stl" />
          </geometry>
        </collision>
      </xacro:if>
      <xacro:if value="${collision_type == 'convex_hull'}">
        <collision>
          <origin xyz="0 0 0" rpy="0 0 0" />
          <geometry>
            <mesh
              filename="package://galbot_one_golf_description/meshes/collision/head/head_link1/convex_hull/head_link1_convex_hull.stl" />
          </geometry>
        </collision>
      </xacro:if>
      <xacro:if value="${collision_type == 'convex_decomposition'}">
        <collision>
          <origin xyz="0 0 0" rpy="0 0 0" />
          <geometry>
            <mesh
              filename="package://galbot_one_golf_description/meshes/collision/head/head_link1/convex_decomposition/head_link1_convex_decomposition_0.stl" />
          </geometry>
        </collision>
        <collision>
          <origin xyz="0 0 0" rpy="0 0 0" />
          <geometry>
            <mesh
              filename="package://galbot_one_golf_description/meshes/collision/head/head_link1/convex_decomposition/head_link1_convex_decomposition_1.stl" />
          </geometry>
        </collision>
        <collision>
          <origin xyz="0 0 0" rpy="0 0 0" />
          <geometry>
            <mesh
              filename="package://galbot_one_golf_description/meshes/collision/head/head_link1/convex_decomposition/head_link1_convex_decomposition_2.stl" />
          </geometry>
        </collision>
        <collision>
          <origin xyz="0 0 0" rpy="0 0 0" />
          <geometry>
            <mesh
              filename="package://galbot_one_golf_description/meshes/collision/head/head_link1/convex_decomposition/head_link1_convex_decomposition_3.stl" />
          </geometry>
        </collision>
        <collision>
          <origin xyz="0 0 0" rpy="0 0 0" />
          <geometry>
            <mesh
              filename="package://galbot_one_golf_description/meshes/collision/head/head_link1/convex_decomposition/head_link1_convex_decomposition_4.stl" />
          </geometry>
        </collision>
        <collision>
          <origin xyz="0 0 0" rpy="0 0 0" />
          <geometry>
            <mesh
              filename="package://galbot_one_golf_description/meshes/collision/head/head_link1/convex_decomposition/head_link1_convex_decomposition_5.stl" />
          </geometry>
        </collision>
        <collision>
          <origin xyz="0 0 0" rpy="0 0 0" />
          <geometry>
            <mesh
              filename="package://galbot_one_golf_description/meshes/collision/head/head_link1/convex_decomposition/head_link1_convex_decomposition_6.stl" />
          </geometry>
        </collision>
        <collision>
          <origin xyz="0 0 0" rpy="0 0 0" />
          <geometry>
            <mesh
              filename="package://galbot_one_golf_description/meshes/collision/head/head_link1/convex_decomposition/head_link1_convex_decomposition_7.stl" />
          </geometry>
        </collision>
        <collision>
          <origin xyz="0 0 0" rpy="0 0 0" />
          <geometry>
            <mesh
              filename="package://galbot_one_golf_description/meshes/collision/head/head_link1/convex_decomposition/head_link1_convex_decomposition_8.stl" />
          </geometry>
        </collision>
        <collision>
          <origin xyz="0 0 0" rpy="0 0 0" />
          <geometry>
            <mesh
              filename="package://galbot_one_golf_description/meshes/collision/head/head_link1/convex_decomposition/head_link1_convex_decomposition_9.stl" />
          </geometry>
        </collision>
        <collision>
          <origin xyz="0 0 0" rpy="0 0 0" />
          <geometry>
            <mesh
              filename="package://galbot_one_golf_description/meshes/collision/head/head_link1/convex_decomposition/head_link1_convex_decomposition_10.stl" />
          </geometry>
        </collision>
        <collision>
          <origin xyz="0 0 0" rpy="0 0 0" />
          <geometry>
            <mesh
              filename="package://galbot_one_golf_description/meshes/collision/head/head_link1/convex_decomposition/head_link1_convex_decomposition_11.stl" />
          </geometry>
        </collision>
      </xacro:if>
    </link>
    <joint name="${name}_joint1" type="revolute">
      <origin xyz="0 0 0" rpy="0 0 0" />
      <parent link="${name}_base_link" />
      <child link="${name}_link1" />
      <axis xyz="0 0 1" />
      <limit lower="-1.5208" upper="1.5208" effort="4" velocity="1.5" />
    </joint>

    <link name="${name}_link2">
      <inertial>
        <origin xyz="0.01835 -0.033479999999999996 0.00642" rpy="0 0 0" />
        <mass value="0.81"/>
        <inertia ixx="0.00000399161" ixy="0.00000129825" ixz="0.00000000392"
             iyy="0.00000372602" iyz="0.00000000775" izz="0.00000553062"/>
      </inertial>
      <visual>
        <origin xyz="0 0 0" rpy="0 0 0" />
        <geometry>
          <mesh
            filename="package://galbot_one_golf_description/meshes/visual/head/head_link2/obj/head_link2.obj" />
        </geometry>
      </visual>
      <xacro:if value="${collision_type == 'sphere'}">
        <collision>
          <origin xyz="0 0 0" rpy="0 0 0" />
          <geometry>
            <sphere radius="0.001" />
          </geometry>
        </collision>
      </xacro:if>
      <xacro:if value="${collision_type == 'mesh'}">
        <collision>
          <origin xyz="0 0 0" rpy="0 0 0" />
          <geometry>
            <mesh
              filename="package://galbot_one_golf_description/meshes/collision/head/head_link2/original/head_link2.stl" />
          </geometry>
        </collision>
      </xacro:if>
      <xacro:if value="${collision_type == 'convex_hull'}">
        <collision>
          <origin xyz="0 0 0" rpy="0 0 0" />
          <geometry>
            <mesh
              filename="package://galbot_one_golf_description/meshes/collision/head/head_link2/convex_hull/head_link2_convex_hull.stl" />
          </geometry>
        </collision>
      </xacro:if>
      <xacro:if value="${collision_type == 'convex_decomposition'}">
        <collision>
          <origin xyz="0 0 0" rpy="0 0 0" />
          <geometry>
            <mesh
              filename="package://galbot_one_golf_description/meshes/collision/head/head_link2/convex_decomposition/head_link2_convex_decomposition_0.stl" />
          </geometry>
        </collision>
        <collision>
          <origin xyz="0 0 0" rpy="0 0 0" />
          <geometry>
            <mesh
              filename="package://galbot_one_golf_description/meshes/collision/head/head_link2/convex_decomposition/head_link2_convex_decomposition_1.stl" />
          </geometry>
        </collision>
        <collision>
          <origin xyz="0 0 0" rpy="0 0 0" />
          <geometry>
            <mesh
              filename="package://galbot_one_golf_description/meshes/collision/head/head_link2/convex_decomposition/head_link2_convex_decomposition_2.stl" />
          </geometry>
        </collision>
        <collision>
          <origin xyz="0 0 0" rpy="0 0 0" />
          <geometry>
            <mesh
              filename="package://galbot_one_golf_description/meshes/collision/head/head_link2/convex_decomposition/head_link2_convex_decomposition_3.stl" />
          </geometry>
        </collision>
        <collision>
          <origin xyz="0 0 0" rpy="0 0 0" />
          <geometry>
            <mesh
              filename="package://galbot_one_golf_description/meshes/collision/head/head_link2/convex_decomposition/head_link2_convex_decomposition_4.stl" />
          </geometry>
        </collision>
        <collision>
          <origin xyz="0 0 0" rpy="0 0 0" />
          <geometry>
            <mesh
              filename="package://galbot_one_golf_description/meshes/collision/head/head_link2/convex_decomposition/head_link2_convex_decomposition_5.stl" />
          </geometry>
        </collision>
        <collision>
          <origin xyz="0 0 0" rpy="0 0 0" />
          <geometry>
            <mesh
              filename="package://galbot_one_golf_description/meshes/collision/head/head_link2/convex_decomposition/head_link2_convex_decomposition_6.stl" />
          </geometry>
        </collision>
        <collision>
          <origin xyz="0 0 0" rpy="0 0 0" />
          <geometry>
            <mesh
              filename="package://galbot_one_golf_description/meshes/collision/head/head_link2/convex_decomposition/head_link2_convex_decomposition_7.stl" />
          </geometry>
        </collision>
        <collision>
          <origin xyz="0 0 0" rpy="0 0 0" />
          <geometry>
            <mesh
              filename="package://galbot_one_golf_description/meshes/collision/head/head_link2/convex_decomposition/head_link2_convex_decomposition_8.stl" />
          </geometry>
        </collision>
        <collision>
          <origin xyz="0 0 0" rpy="0 0 0" />
          <geometry>
            <mesh
              filename="package://galbot_one_golf_description/meshes/collision/head/head_link2/convex_decomposition/head_link2_convex_decomposition_9.stl" />
          </geometry>
        </collision>
        <collision>
          <origin xyz="0 0 0" rpy="0 0 0" />
          <geometry>
            <mesh
              filename="package://galbot_one_golf_description/meshes/collision/head/head_link2/convex_decomposition/head_link2_convex_decomposition_10.stl" />
          </geometry>
        </collision>
        <collision>
          <origin xyz="0 0 0" rpy="0 0 0" />
          <geometry>
            <mesh
              filename="package://galbot_one_golf_description/meshes/collision/head/head_link2/convex_decomposition/head_link2_convex_decomposition_11.stl" />
          </geometry>
        </collision>
        <collision>
          <origin xyz="0 0 0" rpy="0 0 0" />
          <geometry>
            <mesh
              filename="package://galbot_one_golf_description/meshes/collision/head/head_link2/convex_decomposition/head_link2_convex_decomposition_12.stl" />
          </geometry>
        </collision>
        <collision>
          <origin xyz="0 0 0" rpy="0 0 0" />
          <geometry>
            <mesh
              filename="package://galbot_one_golf_description/meshes/collision/head/head_link2/convex_decomposition/head_link2_convex_decomposition_13.stl" />
          </geometry>
        </collision>
        <collision>
          <origin xyz="0 0 0" rpy="0 0 0" />
          <geometry>
            <mesh
              filename="package://galbot_one_golf_description/meshes/collision/head/head_link2/convex_decomposition/head_link2_convex_decomposition_14.stl" />
          </geometry>
        </collision>
      </xacro:if>
    </link>
    <joint name="${name}_joint2" type="revolute">
      <origin xyz="0 0 0" rpy="${-M_PI/2} 0 0" />
      <parent link="${name}_link1" />
      <child link="${name}_link2" />
      <axis xyz="0 0 1" />
      <!-- Soft limit 0.03 radians lower="-0.2443461" upper="0.5235988" -->
      <limit lower="-0.2143461" upper="0.4935988" effort="4" velocity="1.5" />
    </joint>

    <link name="${name}_end_effector_mount_link">
      <inertial>
        <origin xyz="0 0 0" rpy="0 0 0" />
        <mass value="0" />
        <inertia ixx="0" ixy="0" ixz="0" iyy="0" iyz="0" izz="0" />
      </inertial>
    </link>
    <joint name="${name}_end_effector_mount_joint" type="fixed">
      <origin xyz="0 0 0" rpy="0 0 0" />
      <parent link="${name}_link2" />
      <child link="${name}_end_effector_mount_link" />
      <axis xyz="0 0 0" />
    </joint>

  </xacro:macro>
</robot>